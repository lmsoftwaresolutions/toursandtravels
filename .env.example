# Copy this file to .env and replace all placeholder values before running the app.

# ========================
# Database Configuration
# ========================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=your_database_name
DATABASE_URL=postgresql://your_postgres_user:your_strong_postgres_password@db:5432/your_database_name
DB_HOST=db

# ========================
# Security
# ========================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_a_long_random_secret_key

# ========================
# Frontend
# ========================
# Frontend talks to nginx; nginx proxies to backend
VITE_API_URL=/api
